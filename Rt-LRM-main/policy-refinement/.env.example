# ===========================================
# policy-refinement 环境变量配置示例
# 请复制本文件为 .env，并填入你自己的 API Key
# ===========================================

# ------------------------------------------------------------------
# 1. 通用 fallback（主流程 Agent / Simulator）
#    当各模块未单独配置时，默认回退到这一对 key/base。
#    用途：scripts/emulate.py, scripts/run.py, toolemu/utils/llm.py
# ------------------------------------------------------------------
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-openai-key

# ------------------------------------------------------------------
# 2. 主流程模型专用配置（可选，覆盖通用 fallback）
#    toolemu/utils/llm.py 会根据 --agent-model-name 自动选择对应变量。
#    若未设置，则回退到 OPENAI_API_BASE / OPENAI_API_KEY。
# ------------------------------------------------------------------
# GPT-3.5 系列（如 gpt-3.5-turbo, gpt-3.5-turbo-16k）
GPT35_API_BASE=https://api.openai.com/v1
GPT35_API_KEY=sk-your-gpt35-key

# GPT-4 系列（如 gpt-4, gpt-4-0613, gpt-4o）
GPT4_API_BASE=https://api.openai.com/v1
GPT4_API_KEY=sk-your-gpt4-key

# Llama 系列（通过第三方兼容接口调用，如 yunwu.ai）
LLAMA_API_BASE=https://your-llama-proxy.com/v1
LLAMA_API_KEY=sk-your-llama-key

# Qwen 系列（通过第三方兼容接口调用，如 dashscope）
QWEN_API_BASE=https://your-qwen-proxy.com/v1
QWEN_API_KEY=sk-your-qwen-key

# ------------------------------------------------------------------
# 3. Self-Defense 安全检查 Judge
#    用途：self_defense_agent.py 中的实时动作安全检查 (_self_check)
#    默认模型：gpt-3.5-turbo-16k-0613
# ------------------------------------------------------------------
SELF_DEFENSE_API_BASE=https://api.openai.com/v1
SELF_DEFENSE_API_KEY=sk-your-self-defense-judge-key

# ------------------------------------------------------------------
# 4. LCO / Genetic 投票 Judge
#    用途：MyAgent.py 中的 _vote_actions()，让 LLM 从多个候选动作中
#          选出“最安全且最有效”的动作。若返回 -1 则拒绝执行。
#    默认模型：gpt-4o
# ------------------------------------------------------------------
VOTE_API_BASE=https://api.openai.com/v1
VOTE_API_KEY=sk-your-vote-judge-key

# ------------------------------------------------------------------
# 5. LCO / Genetic Fitness 评估
#    用途：MyAgent.py 中的 _predict_fitness()，对候选动作从
#          目标相关性、上下文一致性、安全性三维度打分。
#    默认模型：gpt-4o
# ------------------------------------------------------------------
FITNESS_API_BASE=https://api.openai.com/v1
FITNESS_API_KEY=sk-your-fitness-evaluator-key

# ------------------------------------------------------------------
# 6. 离线评估脚本（Evaluation Scripts）
#    用途：
#      - evaluation_scripts/traj_helpfulness.py   : 轨迹 helpfulness 评分
#      - evaluation_scripts/ICRH_Detect.py        : ICRH 检测
#      - evaluation_scripts/pairwise_eval.py      : pairwise 安全对比
#    默认模型：gpt-4o
# ------------------------------------------------------------------
EVAL_API_BASE=https://api.openai.com/v1
EVAL_API_KEY=sk-your-evaluator-key
